              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
  b.book_id, b.title, b.isbn13,
  CAST(STRING_AGG(a.author_name, ', ') AS VARCHAR(2000)) AS author_name,
  p.publisher_name,
  bl.language_name, bl.language_code,
  b.num_pages, b.publication_date
FROM gravity_books.dbo.book b
LEFT JOIN gravity_books.dbo.book_author ba
       ON b.book_id     = ba.book_id
LEFT JOIN gravity_books.dbo.author a
       ON ba.author_id  = a.author_id
LEFT JOIN gravity_books.dbo.publisher p
       ON b.publisher_id = p.publisher_id
LEFT JOIN gravity_books.dbo.book_language bl
       ON b.language_id = bl.language_id
GROUP BY b.book_id, b.title, b.isbn13,
  p.publisher_name, bl.language_name,
  bl.language_code, b.num_pages, b.publication_date</property>
