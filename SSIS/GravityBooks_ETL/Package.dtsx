                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
  o.order_id, ol.line_id,
  o.order_date,
  o.customer_id,
  ol.book_id,
  o.shipping_method_id,
  ol.price          AS unit_price,
  1                 AS quantity,
  ol.price * 1      AS total_amount
FROM gravity_books.dbo.cust_order o
JOIN gravity_books.dbo.order_line ol
  ON o.order_id = ol.order_id
WHERE o.order_date IS NOT NULL</property>
