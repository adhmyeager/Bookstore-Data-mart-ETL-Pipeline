                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
  c.customer_id,
  c.first_name,
  c.last_name,
  c.email,
  a.city,
  co.country_name AS country
FROM gravity_books.dbo.customer c
OUTER APPLY (
  SELECT TOP 1 a.city, a.country_id
  FROM gravity_books.dbo.customer_address ca
  JOIN gravity_books.dbo.address a ON ca.address_id = a.address_id
  WHERE ca.customer_id = c.customer_id
  ORDER BY ca.address_id   -- or any determinist order
) a
LEFT JOIN gravity_books.dbo.country co ON a.country_id = co.country_id;</property>
